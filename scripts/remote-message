#!/usr/bin/env bash
# remote-message — send a message to another NanoClaw agent
#
# Usage:
#   remote-message <target> <message>
#   remote-message --list              # list known agents
#   remote-message --help
#
# Reads agent config from data/agents.json (relative to NANOCLAW_DIR or script location).
# Service agents get IPC input injection (real-time). Dev agents get inbox delivery.

set -euo pipefail

# Find nanoclaw root
if [[ -n "${NANOCLAW_DIR:-}" ]]; then
  ROOT="$NANOCLAW_DIR"
else
  ROOT="$(cd "$(dirname "$0")/.." && pwd)"
fi

CONFIG="$ROOT/data/agents.json"

if [[ ! -f "$CONFIG" ]]; then
  echo "Error: agents config not found at $CONFIG" >&2
  exit 1
fi

show_help() {
  echo "Usage: remote-message <target> <message>"
  echo "       remote-message --list"
  echo ""
  echo "Targets are defined in data/agents.json"
  echo "Service agents: message injected via IPC (real-time)"
  echo "Dev agents: message written to inbox (check with check-inbox)"
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" || -z "${1:-}" ]]; then
  show_help
  exit 0
fi

if [[ "$1" == "--list" || "$1" == "-l" ]]; then
  echo "Known agents:"
  python3 -c "
import json
with open('$CONFIG') as f:
    agents = json.load(f).get('agents', {})
for aid, a in agents.items():
    desc = a.get('description', a.get('type', ''))
    host = a.get('host', '?')
    print(f'  {aid:25s} {desc} [{host}]')
"
  exit 0
fi

TARGET="$1"
shift
MESSAGE="$*"

if [[ -z "$MESSAGE" ]]; then
  echo "Error: message is required" >&2
  show_help
  exit 1
fi

# Parse agent config and build the JSON payload with python3 (handles escaping properly)
FILENAME="$(date +%s)-$(od -An -N3 -tx1 /dev/urandom | tr -d ' \n').json"

RESULT=$(python3 -c "
import json, sys, os

with open('$CONFIG') as f:
    config = json.load(f)
    agents = config.get('agents', {})
    self_host = config.get('self', 'unknown')

target = sys.argv[1]
message = sys.argv[2]

# Build sender identity from config
group_folder = os.environ.get('NANOCLAW_GROUP_FOLDER', '')
sender = f'{group_folder}@{self_host}' if group_folder else f'dev@{self_host}'

a = agents.get(target)
if not a:
    avail = ', '.join(agents.keys())
    print(f'ERROR:Unknown agent \"{target}\". Available: {avail}', file=sys.stderr)
    sys.exit(1)

host = a['host']
ncdir = a['nanoclaw_dir']
atype = a['type']
group = a.get('group', '')

if atype == 'service' and group:
    directory = f'{ncdir}/data/ipc/{group}/messages'
    payload = json.dumps({'type': 'inject', 'targetGroup': group, 'text': f'[From {sender}] {message}'}, indent=2)
    print(f'{host}|{directory}|service|{sender}')
    print(payload)
else:
    # Dev agent: use claude -c -p
    print(f'{host}|{ncdir}|dev|{sender}')
" "$TARGET" "$MESSAGE")

# Parse result
HEADER=$(echo "$RESULT" | head -1)

IFS='|' read -r HOST DIR TYPE SENDER <<< "$HEADER"

FULL_MESSAGE="[From $SENDER] $MESSAGE"

if [[ "$TYPE" == "service" ]]; then
  # Service agent: write inject IPC file
  PAYLOAD=$(echo "$RESULT" | tail -n +2)
  if [[ "$HOST" == "localhost" ]]; then
    mkdir -p "$DIR"
    TMPFILE="$DIR/$FILENAME.tmp"
    echo "$PAYLOAD" > "$TMPFILE"
    mv "$TMPFILE" "$DIR/$FILENAME"
  else
    echo "$PAYLOAD" | ssh -o ConnectTimeout=10 "$HOST" "mkdir -p '$DIR' && cat > '$DIR/$FILENAME.tmp' && mv '$DIR/$FILENAME.tmp' '$DIR/$FILENAME'"
  fi
  echo "Message delivered to $TARGET (IPC injection)" >&2
else
  # Dev agent: send via claude -c -p (resumes most recent session)
  ESCAPED_MSG=$(printf '%s' "$FULL_MESSAGE" | sed "s/'/'\\\\''/g")
  if [[ "$HOST" == "localhost" ]]; then
    cd "$DIR" && claude -c -p "$ESCAPED_MSG"
  else
    ssh -o ConnectTimeout=10 "$HOST" "cd '$DIR' && claude -c -p '$ESCAPED_MSG'"
  fi
fi
